{
  "project": {
    "name": "Multi-Agent Swarm Simulator",
    "description": "Decentralized coordination of autonomous agents",
    "author": "tjards",
    "version": "2.0"
  },
  
  "simulation": {
    "Ti": 0,
    "Tf": 360,
    "Ts": 0.02,
    "dimens": 2,
    "verbose": 1,
    "system": "swarm",
    "strategy": "shep",
    "random_seed": 42,
    "f": 0,
    "experimental_save": false
  },
  
  "agents": {
    "nAgents": 13,
    "dynamics": "double_integrator",
    "max_velocity": 2.0,
    "communication_range": 5.0,
    "control_gain": 0.5,
    "quadcopter": {
      "enabled": false,
      "mass": 1.0,
      "gravity": 9.81,
      "motor_max_thrust": 20.0
    }
  },
  
  "targets": {
    "target_type": "static",
    "movement_speed": 0.5
  },
  
  "obstacles": {
    "num_obstacles": 0,
    "obstacle_type": "circular"
  },
  
  "orchestrator": {
    "pin_update_rate": 10,
    "pin_selection_method": "degree_leafs",
    "criteria_table": {
      "radius": true,
      "aperature": false
    },
    "sensor_aperature": 140,
    "learning_ctrl": null
  },
  
  "planner": {
    "techniques": {
      "saber": {
        "a": 5.0,
        "b": 5.0,
        "eps": 0.1,
        "h": 0.2,
        "pi": 3.14159,
        "c1_a": 1.0,
        "c2_a": 2.0,
        "c1_b": 0.0,
        "c2_b": 0.0,
        "c1_g": 2.0,
        "c2_g": 4.472,
        "d": 10.0,
        "d_prime": 6.0,
        "r": 13.0,
        "r_prime": 7.8
      },
      
      "lemni": {
        "c1_d": 1.0,
        "c2_d": 2.0,
        "learning": null,
        "learning_axes": "xz",
        "learning_coupling": true,
        "lemni_type": 0
      },
      
      "reynolds": {
        "escort": 1,
        "cd_1": 0.3,
        "cd_2": 0.4,
        "cd_3": 0.2,
        "cd_track": 0.1,
        "maxu": 10,
        "maxv": 100,
        "recovery": 0,
        "far_away": 300,
        "mode_min_coh": 0,
        "agents_min_coh": 2,
        "r": 10,
        "r_prime": 5
      },
      
      "cao": {
        "d": 1.5,
        "r": 2.0,
        "cmd_min": -10,
        "cmd_max": 10,
        "gain_p": 1.0,
        "gain_v": 0.5,
        "kv": 0.1,
        "ka": 0.1,
        "kr": 0.1,
        "kx": 0.1,
        "d_bar": 1.2,
        "i_cont": 0,
        "gamma_kp": 1.0,
        "H_min": 0.5,
        "mode_malicious": 0,
        "mal_type": 0,
        "mal_kv": 0.1,
        "mal_ka": 0.1,
        "mal_kr": 0.1,
        "mal_kv_hat": 0.1,
        "mal_ka_hat": 0.1,
        "mal_kr_hat": 0.1
      },
      
      "gradient_parameters": {
        "LJ_gain": 1000000,
        "LJ_B": 1,
        "MORSE_beta": 0.5,
        "MORSE_D": 1,
        "gromacs_lambda_val": 0.5,
        "gromacs_A": 1,
        "gromacs_B": 2,
        "gromacs_alpha": 0.5,
        "gromacs_beta": 1.0
      },
      
      "pinning": {
        "gain_p": 1.0,
        "gain_v": 0.5,
        "k_connectivity": 1,
        "hetero_lattice": {
          "hetero_lattice": 0,
          "learning": 0,
          "d_min": 1.0,
          "d": 1.0,
          "r_max": 5.0,
          "update_rate": 10,
          "consensus_method": "consensus"
        }
      },
      
      "circle": {
        "param1": 1.0,
        "c1_d": 2,
        "c2_d": 2.8284,
        "r_max": 50,
        "r_desired": 5,
        "phi_dot_d": 0.05,
        "ref_plane": "horizontal",
        "quat_0_0": 0.0,
        "quat_0_1": 0.0,
        "quat_0_2": 0.0              
      },
      
      "starling": {
        "param1": 1.0
      },
      
      "shep": {
        "nShepherds": 5,
        "r_R": 3,
        "r_O": 5,
        "r_A": 7,
        "r_I": 6.5,
        "a_R": 2,
        "a_O": 2,
        "a_A": 2,
        "a_I": 4,
        "a_V": 2,
        "r_S": 5.5,
        "r_Oi": 3,
        "r_Od": 2,
        "r_Or": 1,
        "a_N": 5,
        "a_R_s": 1,
        "a_R_s_v": 2.0,
        "a_V_s": 1.0,
        "type_shepherd": "haver",
        "type_avoid": "ref_point",
        "cmd_adjust": 0.02
      }
    }
  },
  
  "learner": {
    "algorithm": "CALA",
    "CALA": {
      "num_states": 10,
      "action_min": -1.0,
      "action_max": 1.0,
      "learning_rate": 0.01,
      "variance_init": 0.5,
      "variance_ratio": 0.8,
      "variance_min": 0.01,
      "variance_max": 1.0,
      "epsilon": 0.3,
      "counter_max": 100,
      "counter_synch": true,
      "counter_delay": 10,
      "leader_follower": false,
      "leader": 0
    },
    
    "QL_learning_lattice": {
      "alpha": 0.1,
      "gamma": 0.9,
      "epsilon": 0.2,
      "num_states": 20,
      "num_actions": 4
    },
    
    "consensus": {
      "param1": 1.0
    },
    
    "gradient_estimation": {
      "param1": 1.0
    }
  },
  
  "data": {
    "save_data": true,
    "data_dir": "data/data/",
    "data_file": "data.h5",
    "record_interval": 1,
    "record_agents": true,
    "record_targets": true,
    "record_obstacles": true,
    "record_learning": true
  },
  
  "visualization": {
    "plot_results": true,
    "animate_results": true,
    "plots_dir": "visualization/plots",
    "animations_dir": "visualization/animations",
    "show_trajectory": true,
    "show_connectivity": true
  },
  
  "experiments": {
    "experiment_name": "baseline_lemni",
    "num_runs": 1,
    "save_configs": true,
    "save_metadata": true
  }
}
